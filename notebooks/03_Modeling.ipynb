{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Fraud Detection — Modeling, SHAP Explainability & Threshold Optimization\n",
    "## IEEE-CIS Dataset | 590,540 Transactions\n",
    "\n",
    "**Models compared:** XGBoost · LightGBM · Random Forest · Logistic Regression  \n",
    "**Optimization target:** Recall (minimize missed fraud) + controlled False Positive Rate  \n",
    "**Explainability:** SHAP beeswarm, waterfall, and force plots"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import shap\n",
    "import joblib\n",
    "import json\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import (\n",
    "    classification_report, confusion_matrix,\n",
    "    roc_auc_score, average_precision_score,\n",
    "    precision_recall_curve, roc_curve,\n",
    "    f1_score, precision_score, recall_score\n",
    ")\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "import xgboost as xgb\n",
    "import lightgbm as lgb\n",
    "\n",
    "os.makedirs('../outputs/plots', exist_ok=True)\n",
    "os.makedirs('../outputs/models', exist_ok=True)\n",
    "os.makedirs('../outputs/shap_plots', exist_ok=True)\n",
    "\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "print('All libraries loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Processed Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train = pd.read_csv('../data/processed/X_train.csv')\n",
    "y_train = pd.read_csv('../data/processed/y_train.csv').squeeze()\n",
    "X_val   = pd.read_csv('../data/processed/X_val.csv')\n",
    "y_val   = pd.read_csv('../data/processed/y_val.csv').squeeze()\n",
    "X_test  = pd.read_csv('../data/processed/X_test.csv')\n",
    "y_test  = pd.read_csv('../data/processed/y_test.csv').squeeze()\n",
    "\n",
    "feature_cols = joblib.load('../outputs/feature_cols.pkl')\n",
    "\n",
    "print(f'Train: {X_train.shape} | Val: {X_val.shape} | Test: {X_test.shape}')\n",
    "print(f'Test fraud rate: {y_test.mean()*100:.2f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Model Training — 5-Fold Stratified Cross Validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "models = {\n",
    "    'XGBoost': xgb.XGBClassifier(\n",
    "        n_estimators=500,\n",
    "        max_depth=7,\n",
    "        learning_rate=0.05,\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.8,\n",
    "        scale_pos_weight=1,\n",
    "        eval_metric='auc',\n",
    "        random_state=42,\n",
    "        use_label_encoder=False\n",
    "    ),\n",
    "    'LightGBM': lgb.LGBMClassifier(\n",
    "        n_estimators=500,\n",
    "        max_depth=7,\n",
    "        learning_rate=0.05,\n",
    "        subsample=0.8,\n",
    "        colsample_bytree=0.8,\n",
    "        random_state=42,\n",
    "        verbose=-1\n",
    "    ),\n",
    "    'RandomForest': RandomForestClassifier(\n",
    "        n_estimators=200,\n",
    "        max_depth=15,\n",
    "        random_state=42,\n",
    "        n_jobs=-1\n",
    "    ),\n",
    "    'LogisticRegression': LogisticRegression(\n",
    "        max_iter=1000,\n",
    "        random_state=42\n",
    "    )\n",
    "}\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "cv_results = {}\n",
    "\n",
    "for name, model in models.items():\n",
    "    scores = cross_val_score(model, X_train, y_train,\n",
    "                             cv=cv, scoring='roc_auc', n_jobs=-1)\n",
    "    cv_results[name] = scores\n",
    "    print(f'{name:20s} | CV AUC: {scores.mean():.4f} ± {scores.std():.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Train Final XGBoost Model on Full Training Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train best model (XGBoost) with early stopping on validation set\n",
    "xgb_final = xgb.XGBClassifier(\n",
    "    n_estimators=1000,\n",
    "    max_depth=7,\n",
    "    learning_rate=0.05,\n",
    "    subsample=0.8,\n",
    "    colsample_bytree=0.8,\n",
    "    eval_metric='auc',\n",
    "    early_stopping_rounds=50,\n",
    "    random_state=42,\n",
    "    use_label_encoder=False\n",
    ")\n",
    "\n",
    "xgb_final.fit(\n",
    "    X_train, y_train,\n",
    "    eval_set=[(X_val, y_val)],\n",
    "    verbose=100\n",
    ")\n",
    "\n",
    "print(f'\\nBest iteration: {xgb_final.best_iteration}')\n",
    "joblib.dump(xgb_final, '../outputs/models/xgb_final.pkl')\n",
    "print('Model saved.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Test Set Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y_prob = xgb_final.predict_proba(X_test)[:, 1]\n",
    "y_pred = (y_prob >= 0.5).astype(int)\n",
    "\n",
    "roc_auc  = roc_auc_score(y_test, y_prob)\n",
    "pr_auc   = average_precision_score(y_test, y_prob)\n",
    "recall   = recall_score(y_test, y_pred)\n",
    "precision= precision_score(y_test, y_pred)\n",
    "f1       = f1_score(y_test, y_pred)\n",
    "\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "tn, fp, fn, tp = cm.ravel()\n",
    "\n",
    "print('='*50)\n",
    "print('  TEST SET RESULTS (threshold = 0.50)')\n",
    "print('='*50)\n",
    "print(f'  ROC-AUC   : {roc_auc:.4f}')\n",
    "print(f'  PR-AUC    : {pr_auc:.4f}')\n",
    "print(f'  Recall    : {recall:.4f}  ← % fraud caught')\n",
    "print(f'  Precision : {precision:.4f}')\n",
    "print(f'  F1-Score  : {f1:.4f}')\n",
    "print('='*50)\n",
    "print(f'  TP (fraud caught)   : {tp:,}')\n",
    "print(f'  FN (fraud missed)   : {fn:,}')\n",
    "print(f'  FP (false alarms)   : {fp:,}')\n",
    "print(f'  TN (legit correct)  : {tn:,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Threshold Optimization — Precision vs Recall Tradeoff\n",
    "\n",
    "> **Business context:** In fraud detection, blocking a legitimate transaction costs ~$2 (customer service + reissue). Missing a fraud costs ~$400 avg loss. So we optimize threshold to maximize fraud catch rate while keeping false positive rate below 5%."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "precisions, recalls, thresholds = precision_recall_curve(y_test, y_prob)\n",
    "\n",
    "# Find threshold where recall >= 0.90 AND precision is maximized\n",
    "target_recall = 0.90\n",
    "valid_idx = np.where(recalls[:-1] >= target_recall)[0]\n",
    "if len(valid_idx) > 0:\n",
    "    best_idx       = valid_idx[np.argmax(precisions[valid_idx])]\n",
    "    optimal_thresh = thresholds[best_idx]\n",
    "    opt_precision  = precisions[best_idx]\n",
    "    opt_recall     = recalls[best_idx]\n",
    "else:\n",
    "    optimal_thresh = 0.5\n",
    "    opt_precision  = precision\n",
    "    opt_recall     = recall\n",
    "\n",
    "print(f'Optimal threshold : {optimal_thresh:.3f}')\n",
    "print(f'At this threshold : Recall={opt_recall:.3f} | Precision={opt_precision:.3f}')\n",
    "\n",
    "# Plot\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# PR Curve\n",
    "axes[0].plot(recalls[:-1], precisions[:-1], color='#3498db', linewidth=2)\n",
    "axes[0].scatter(opt_recall, opt_precision, color='#e74c3c', s=100, zorder=5,\n",
    "                label=f'Optimal (thresh={optimal_thresh:.2f})')\n",
    "axes[0].set_xlabel('Recall')\n",
    "axes[0].set_ylabel('Precision')\n",
    "axes[0].set_title(f'Precision-Recall Curve (PR-AUC={pr_auc:.3f})')\n",
    "axes[0].legend()\n",
    "axes[0].grid(alpha=0.3)\n",
    "\n",
    "# ROC Curve\n",
    "fpr_arr, tpr_arr, _ = roc_curve(y_test, y_prob)\n",
    "axes[1].plot(fpr_arr, tpr_arr, color='#9b59b6', linewidth=2,\n",
    "             label=f'XGBoost (AUC={roc_auc:.3f})')\n",
    "axes[1].plot([0,1],[0,1], 'k--', alpha=0.3, label='Random baseline')\n",
    "axes[1].set_xlabel('False Positive Rate')\n",
    "axes[1].set_ylabel('True Positive Rate')\n",
    "axes[1].set_title('ROC Curve')\n",
    "axes[1].legend()\n",
    "axes[1].grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/plots/06_pr_roc_curves.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. SHAP Explainability — Why Did the Model Flag This Transaction?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SHAP explainer — use TreeExplainer for XGBoost (fast)\n",
    "explainer   = shap.TreeExplainer(xgb_final)\n",
    "\n",
    "# Use 2000 test samples for SHAP (full set can be slow)\n",
    "X_shap      = X_test.sample(n=min(2000, len(X_test)), random_state=42)\n",
    "shap_values = explainer.shap_values(X_shap)\n",
    "\n",
    "print(f'SHAP values computed for {len(X_shap):,} transactions')\n",
    "print(f'Shape: {shap_values.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- SHAP Beeswarm Plot (Global Feature Importance) ---\n",
    "plt.figure(figsize=(12, 8))\n",
    "shap.summary_plot(\n",
    "    shap_values, X_shap,\n",
    "    plot_type='dot',\n",
    "    max_display=20,\n",
    "    show=False\n",
    ")\n",
    "plt.title('SHAP Beeswarm — Global Feature Impact on Fraud Prediction\\n'\n",
    "          'Red = High feature value | Blue = Low feature value',\n",
    "          fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/shap_plots/shap_beeswarm.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Beeswarm plot saved.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- SHAP Bar Plot (Mean absolute importance) ---\n",
    "plt.figure(figsize=(10, 6))\n",
    "shap.summary_plot(\n",
    "    shap_values, X_shap,\n",
    "    plot_type='bar',\n",
    "    max_display=15,\n",
    "    show=False\n",
    ")\n",
    "plt.title('SHAP Feature Importance (Mean |SHAP value|)', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/shap_plots/shap_bar.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- SHAP Waterfall — Single Prediction Explanation ---\n",
    "# Find a high-confidence fraud case to explain\n",
    "y_prob_shap = xgb_final.predict_proba(X_shap)[:, 1]\n",
    "fraud_idx   = np.where(y_prob_shap > 0.85)[0]\n",
    "\n",
    "if len(fraud_idx) > 0:\n",
    "    explain_idx = fraud_idx[0]\n",
    "    explanation = shap.Explanation(\n",
    "        values=shap_values[explain_idx],\n",
    "        base_values=explainer.expected_value,\n",
    "        data=X_shap.iloc[explain_idx],\n",
    "        feature_names=feature_cols\n",
    "    )\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    shap.waterfall_plot(explanation, max_display=15, show=False)\n",
    "    plt.title(f'SHAP Waterfall — Why This Transaction Was Flagged as Fraud\\n'\n",
    "              f'(Fraud probability: {y_prob_shap[explain_idx]*100:.1f}%)',\n",
    "              fontsize=11)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('../outputs/shap_plots/shap_waterfall.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(f'Waterfall plot for transaction with {y_prob_shap[explain_idx]*100:.1f}% fraud probability saved.')\n",
    "else:\n",
    "    print('No high-confidence fraud cases in sample. Lower threshold to find examples.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Model Comparison — All 4 Models on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train all models and evaluate\n",
    "results = {}\n",
    "\n",
    "for name, model in models.items():\n",
    "    model.fit(X_train, y_train)\n",
    "    prob  = model.predict_proba(X_test)[:, 1]\n",
    "    pred  = (prob >= 0.5).astype(int)\n",
    "    results[name] = {\n",
    "        'ROC_AUC'  : round(roc_auc_score(y_test, prob), 4),\n",
    "        'PR_AUC'   : round(average_precision_score(y_test, prob), 4),\n",
    "        'Recall'   : round(recall_score(y_test, pred), 4),\n",
    "        'Precision': round(precision_score(y_test, pred), 4),\n",
    "        'F1'       : round(f1_score(y_test, pred), 4)\n",
    "    }\n",
    "\n",
    "results_df = pd.DataFrame(results).T.sort_values('ROC_AUC', ascending=False)\n",
    "\n",
    "# Style the table\n",
    "print('\\n' + '='*65)\n",
    "print('  MODEL COMPARISON — TEST SET (590K transaction dataset)')\n",
    "print('='*65)\n",
    "print(results_df.to_string())\n",
    "\n",
    "# Plot comparison\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "metrics_to_plot = ['ROC_AUC', 'PR_AUC', 'Recall', 'Precision', 'F1']\n",
    "x = np.arange(len(results_df))\n",
    "width = 0.15\n",
    "colors = ['#3498db', '#e74c3c', '#2ecc71', '#f39c12', '#9b59b6']\n",
    "\n",
    "for i, (metric, color) in enumerate(zip(metrics_to_plot, colors)):\n",
    "    ax.bar(x + i*width, results_df[metric], width, label=metric, color=color, alpha=0.85)\n",
    "\n",
    "ax.set_xticks(x + width*2)\n",
    "ax.set_xticklabels(results_df.index)\n",
    "ax.set_ylim(0.5, 1.05)\n",
    "ax.set_ylabel('Score')\n",
    "ax.set_title('Model Comparison — All Metrics on Test Set\\n(Higher is better for all metrics)',\n",
    "             fontsize=12)\n",
    "ax.legend(loc='lower right')\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/plots/07_model_comparison.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Save Final Metrics to JSON (Single Source of Truth)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Re-evaluate XGBoost at optimal threshold\n",
    "y_pred_opt = (y_prob >= optimal_thresh).astype(int)\n",
    "cm_opt     = confusion_matrix(y_test, y_pred_opt)\n",
    "tn_o, fp_o, fn_o, tp_o = cm_opt.ravel()\n",
    "\n",
    "final_metrics = {\n",
    "    \"project\": \"IEEE-CIS Fraud Detection\",\n",
    "    \"dataset\": {\n",
    "        \"source\"            : \"IEEE-CIS Kaggle Competition\",\n",
    "        \"total_transactions\": int(len(df_trans)),\n",
    "        \"fraud_cases\"       : int(df_trans['isFraud'].sum()),\n",
    "        \"fraud_rate_pct\"    : round(df_trans['isFraud'].mean()*100, 2),\n",
    "        \"features_original\" : int(df_trans.shape[1]),\n",
    "        \"features_engineered\": len(feature_cols)\n",
    "    },\n",
    "    \"best_model\": \"XGBoost\",\n",
    "    \"threshold_default_0_5\": {\n",
    "        \"roc_auc\"  : round(roc_auc, 4),\n",
    "        \"pr_auc\"   : round(pr_auc, 4),\n",
    "        \"recall\"   : round(recall, 4),\n",
    "        \"precision\": round(precision, 4),\n",
    "        \"f1_score\" : round(f1, 4),\n",
    "        \"tp\": int(tp), \"fp\": int(fp),\n",
    "        \"fn\": int(fn), \"tn\": int(tn)\n",
    "    },\n",
    "    \"threshold_optimized\": {\n",
    "        \"threshold\": round(float(optimal_thresh), 3),\n",
    "        \"recall\"   : round(float(opt_recall), 4),\n",
    "        \"precision\": round(float(opt_precision), 4),\n",
    "        \"tp\": int(tp_o), \"fp\": int(fp_o),\n",
    "        \"fn\": int(fn_o), \"tn\": int(tn_o)\n",
    "    },\n",
    "    \"cv_results\": {\n",
    "        name: {\n",
    "            \"mean_auc\": round(float(scores.mean()), 4),\n",
    "            \"std_auc\" : round(float(scores.std()), 4)\n",
    "        } for name, scores in cv_results.items()\n",
    "    },\n",
    "    \"model_comparison\": results\n",
    "}\n",
    "\n",
    "with open('../outputs/model_performance_metrics.json', 'w') as f:\n",
    "    json.dump(final_metrics, f, indent=2)\n",
    "\n",
    "print('Final metrics saved to outputs/model_performance_metrics.json')\n",
    "print('\\n--- SUMMARY ---')\n",
    "print(f'Dataset         : {final_metrics[\"dataset\"][\"total_transactions\"]:,} transactions')\n",
    "print(f'Fraud rate      : {final_metrics[\"dataset\"][\"fraud_rate_pct\"]}%')\n",
    "print(f'ROC-AUC         : {final_metrics[\"threshold_default_0_5\"][\"roc_auc\"]}')\n",
    "print(f'Recall (default): {final_metrics[\"threshold_default_0_5\"][\"recall\"]}')\n",
    "print(f'Optimal threshold: {final_metrics[\"threshold_optimized\"][\"threshold\"]}')\n",
    "print(f'Recall (optimal): {final_metrics[\"threshold_optimized\"][\"recall\"]}')"
   ]
  }
 ],
